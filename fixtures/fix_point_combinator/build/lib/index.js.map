class Fix<A, B> {
    f: fn(f: fn(arg: A) -> B) -> fn(arg: A) -> B,
    recurse(self, arg: A) -> B {
        val g = self.f
        return g(self.recurse)(arg)
    },
}

val fix = fn<A, B>(
    f: fn(f: fn(arg: A) -> B) -> fn(arg: A) -> B
) {
    return Fix(f).recurse
}

val fact = fn(cont: fn(n: number) -> number) {
    return fn(n: number) -> number {
        return if n <= 0 { 1 } else { n * cont(n - 1) }
    }
}

val result = fix(fact)(10)
